# ══════════════════════════════════════════════════════════════════════════════
# Starto – Environment Variables Reference
# Copy to .env (Docker Compose) or .env.local (Next.js) and fill in real values.
# NEVER commit files containing real secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=starto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_secure_password

# ─── Backend DB connection ────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/starto
DB_USERNAME=postgres
DB_PASSWORD=change_me_secure_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Backend server ───────────────────────────────────────────────────────────
PORT=9090
# Set to 'update' for local dev; must be 'validate' in production
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ─── CORS (comma-separated allowed origins) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9090

# ─── Firebase – Backend (service account) ─────────────────────────────────────
# Preferred: base64-encoded JSON (no file mounting needed in containers)
# Generate (Linux/Mac):  base64 -w 0 firebase-service-account.json
# Generate (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json"))
FIREBASE_SERVICE_ACCOUNT_B64=

# Local dev fallback — used only when FIREBASE_SERVICE_ACCOUNT_B64 is empty
FIREBASE_CONFIG_PATH=src/main/resources/firebase-service-account.json

# ─── Firebase – Frontend (client SDK) ─────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_or_dummy

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx

# Razorpay Subscription Plan IDs (from Razorpay dashboard)
RAZORPAY_PLAN_SPRINT=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_BOOST=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_PRO=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CAPTAIN=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CAPTAIN_PRO=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_PRO_PLUS=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_GROWTH=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_ANNUAL=plan_xxxxxxxxxxxxxxxxxxxx

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ─── Frontend API base URL ────────────────────────────────────────────────────
# Local dev:          http://localhost:8080
# Docker Compose:     http://backend:8080
# Production:         https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:9090

# ─── Android (add to starto-android/local.properties — gitignored) ────────────
# API_BASE_URL=http://10.0.2.2:8080        (emulator pointing to local backend)
# API_BASE_URL=https://api.yourdomain.com  (production)

# ─── Antigravity deployment token ─────────────────────────────────────────────
ANTIGRAVITY_TOKEN=your_antigravity_api_token
